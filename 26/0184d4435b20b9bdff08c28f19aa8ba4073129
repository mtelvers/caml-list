  =E2=94=82 $ curl -fsSL https://apt.robur.coop/gpg.pub | \
  =E2=94=82   gpg --dearmor > /etc/apt/trusted.gpg.d/apt.robur.coop.gpg
  =E2=94=82 $ echo "deb [signed-by=3D/etc/apt/trusted.gpg.d/apt.robur.coop.=
gpg] https://apt.robur.coop ubuntu-24.04 main" > /etc/apt/sources.list.d/ro=
bur.list
