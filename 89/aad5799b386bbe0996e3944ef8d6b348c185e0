ppf <span style=3D"color: #ca3400;">"@[{@ %a@ }@]"</span>=20
    (<span style=3D"color: #557400; font-weight: bold;">Format.</span>pp_pr=
int_seq ~pp_sep pp_elt) (<span style=3D"color: #557400; font-weight: bold;"=
>M.</span>to_seq set)=20
